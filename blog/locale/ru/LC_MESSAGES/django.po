"\n"
"Email sent on: %(date)s\n"
msgstr ""
"\n"
"Письмо отправлено: %(date)s\n"

#: .\apps\service\templates\welcome_new_user_template.txt:28
msgid ""
"\n"
"Best regards,\n"
"The BLOG API Team\n"
msgstr ""
"\n"
"С уважением,\n"
"Команда BLOG API\n"

